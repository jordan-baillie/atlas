# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Data cache (large, rebuilt by ingest)
data/cache/

# Logs
logs/

# Pi local settings
.pi/

# Backtest Optuna DBs
backtest/results/*.db

# Generated index (rebuilt by `python -m backtest.index build`)
backtest/results/index.json

# Dashboard generated data (rebuilt by generate_data.py)
dashboard/data/

# Broker credentials — NEVER commit
.env
.env.*
!.env.example
*.secrets.json
*-secrets.json

# OpenD config (contains login credentials)
OpenD.xml
FutuOpenD.xml

# Live trading halt file (runtime only)
.live_halt

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Backup / temp files
*.bak
*.pkl

# Audit L2: additional entries
*.log
*.tmp
audit/
config/active/*.bak*
.pi-swarm/
