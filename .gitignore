# ── Python ───────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# ── Secrets — NEVER commit ───────────────────────────────────────
.env
.env.*
!.env.example
*.secrets.json
*-secrets.json

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log
*.tmp

# ── Runtime state (data/ is state, not code; shared with Crucible) ─
data/live/
data/cache/
data/sharadar/
data/processed/**
data/audit/**
data/backups/**
data/snapshots/
data/*.db
data/*.db-*
data/*.bak*
data/atlas_backup_*.db
data/*_state.json
data/*_verification.json
data/.sync_*
data/.telegram_error_throttle.json
data/price_arbiter_alert_throttle.json
data/parity_alert_cooldown.json
data/chat/
.live_halt

# ── Generated config caches / runtime config state ──────────────
config/active/*.bak*
config/active/**/*.bak*
config/audit_log/**
config/auto_excluded_tickers.json

# ── Dashboard runtime artifacts ──────────────────────────────────
atlas/dashboard/static/finance-data.json
atlas/dashboard/static/sentiment-data.json
dashboard-ui/test-results/
tests/screenshots/

# ── Pi local state ───────────────────────────────────────────────
.pi/
.pi/**
.pi-swarm/
pi-package/atlas-ops/package-lock.json

# ── Tooling caches ───────────────────────────────────────────────
.gitnexus

# ── Backup / temp files ──────────────────────────────────────────
*.bak
*.bak.*
*.pkl
*.done
*.json.pre-*
*.db.pre-*
*.py.pre-*

# ── OS / IDE ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
