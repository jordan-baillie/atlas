#!/bin/bash
# Atlas pre-commit hook: prevent committing secrets
#
# Checks staged files for patterns that look like credentials.
# Also blocks known secret files from being committed.

RED='\033[0;31m'
NC='\033[0m'

# Block generated runtime/state artifacts from being re-tracked.
RUNTIME_GUARD="$(git rev-parse --show-toplevel)/scripts/git-hooks/check_no_runtime_artifacts.py"
if [ -f "$RUNTIME_GUARD" ]; then
    python3 "$RUNTIME_GUARD" || exit 1
fi

# Block exact secret filenames (not partials like .env.example)
BLOCKED_PATTERNS='^\.env$|\.secrets\.json$|atlas-secrets'
MATCHES=$(git diff --cached --name-only | grep -E "$BLOCKED_PATTERNS" || true)

if [ -n "$MATCHES" ]; then
    echo -e "${RED}🚫 BLOCKED: Attempting to commit secret file(s):${NC}"
    echo "$MATCHES"
    echo "   Remove with: git reset HEAD <file>"
    exit 1
fi

# Check staged content for credential patterns
CRED_PATTERNS='password\s*=\s*["\x27][^"\x27]+|api_key\s*=\s*["\x27][^"\x27]+|secret\s*=\s*["\x27][^"\x27]+|MOOMOO_TRADE_PWD\s*=\s*[0-9]|TELEGRAM_BOT_TOKEN\s*=\s*["\x27][0-9]'

CRED_MATCHES=$(git diff --cached --diff-filter=ACM -U0 -- '*.py' '*.json' '*.yml' '*.yaml' '*.env' '*.md' '*.cfg' '*.ini' | grep -iP "$CRED_PATTERNS" | grep -v "\.example" | grep -v "_env\b" | grep -v "unlock_password_env" || true)

if [ -n "$CRED_MATCHES" ]; then
    echo -e "${RED}🚫 BLOCKED: Possible credentials detected in staged files:${NC}"
    echo "$CRED_MATCHES"
    echo ""
    echo "If these are false positives, commit with: git commit --no-verify"
    exit 1
fi

# ── Bash syntax check on staged .sh files ─────────────────────
staged_sh=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.sh$' || true)
if [ -n "$staged_sh" ]; then
    bash_failed=0
    while IFS= read -r f; do
        if [ -f "$f" ] && ! bash -n "$f" 2>&1; then
            echo -e "${RED}🚫 BLOCKED: bash -n syntax error in $f${NC}" >&2
            bash_failed=1
        fi
    done <<< "$staged_sh"
    if [ "$bash_failed" -eq 1 ]; then
        echo "Fix syntax errors before committing." >&2
        exit 1
    fi
fi

# ── Python syntax check on staged .py files ─────────────────
staged_py=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
if [ -n "$staged_py" ]; then
    py_failed=0
    while IFS= read -r f; do
        if [ -f "$f" ] && ! python3 -m py_compile "$f" 2>&1; then
            echo -e "${RED}🚫 BLOCKED: python3 -m py_compile syntax error in $f${NC}" >&2
            py_failed=1
        fi
    done <<< "$staged_py"
    if [ "$py_failed" -eq 1 ]; then
        echo "Fix Python syntax errors before committing." >&2
        exit 1
    fi
fi


# ─── Config/active research gate (per audit 2026-05-06 Rec 1.6) ─────────────
# Block direct edits to config/active/*.json without auto_promote audit trail.
# Override options (both verified working, #319):
#   - Set env var: BYPASS_RESEARCH_GATE="reason" git commit -m "..."
#   - Use --no-verify to skip the hook entirely (audit-traced by git)
#
# NOTE: git does NOT write COMMIT_EDITMSG before the pre-commit hook runs
# (confirmed 2026-05-11), so an in-commit-message marker cannot be read here.
# Use the env var approach or --no-verify.

ACTIVE_CONFIGS=$(git diff --cached --name-only | grep -E "^config/active/[a-z0-9_]+\.json$" || true)

if [ -n "$ACTIVE_CONFIGS" ]; then
    # Check for bypass via env var.
    if [ -n "$BYPASS_RESEARCH_GATE" ]; then
        echo "⚠️  config/active/*.json edit detected — BYPASS_RESEARCH_GATE override: $BYPASS_RESEARCH_GATE"
        # Continue
    else
        # Verify there's a recent auto_promote log entry for each market being changed
        RED_LC='\033[0;31m'
        YELLOW='\033[0;33m'
        NC_LC='\033[0m'
        BLOCKED=0
        for FILE in $ACTIVE_CONFIGS; do
            MARKET=$(basename "$FILE" .json)
            # Look for an entry within last 24h matching this market
            python3 -c "
import json, sys
from pathlib import Path
from datetime import datetime, timezone, timedelta
log = Path('config/promotion_log.json')
if not log.exists():
    sys.exit(2)
try:
    entries = json.loads(log.read_text())
except Exception:
    sys.exit(2)
cutoff = datetime.now(timezone.utc) - timedelta(hours=24)
match = [e for e in entries if e.get('market') == '$MARKET'
         and datetime.fromisoformat(e['timestamp'].replace('Z','+00:00')) > cutoff]
sys.exit(0 if match else 1)
" 2>/dev/null
            STATUS=$?
            if [ $STATUS -ne 0 ]; then
                if [ $BLOCKED -eq 0 ]; then
                    echo -e "${RED_LC}🚫 BLOCKED: config/active/*.json edit without auto_promote() audit trail${NC_LC}"
                    echo ""
                fi
                echo -e "${YELLOW}  $FILE — no auto_promote log entry within 24h for market '$MARKET'${NC_LC}"
                BLOCKED=1
            fi
        done
        if [ $BLOCKED -ne 0 ]; then
            echo ""
            echo "Per audit 2026-05-06 Rec 1.6 — direct config edits are blocked."
            echo "Ways through:"
            echo "  1. Run auto_promote() with this config (proper path)"
            echo "  2. Set env: BYPASS_RESEARCH_GATE='<reason>' git commit -m '...'"
            echo "  3. Use 'git commit --no-verify' (last resort, audit-traced)"
            exit 1
        fi
    fi
fi

# ─── Strategy lifecycle guard (lifecycle-1.6, 2026-05-14) ────────────────────
# Blocks enabling strategies that lack a LIVE/PAPER row in strategy_lifecycle.
# Shares the BYPASS_RESEARCH_GATE escape hatch (set env var to skip).
LIFECYCLE_GUARD="$(git rev-parse --show-toplevel)/scripts/git-hooks/pre-commit-lifecycle-guard.sh"
if [ -f "$LIFECYCLE_GUARD" ]; then
    bash "$LIFECYCLE_GUARD"
fi

exit 0
