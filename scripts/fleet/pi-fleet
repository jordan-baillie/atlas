#!/usr/bin/env bash
# pi-fleet — launch a 4-pane tmux mockup of parallel pi agents.
#
# Layout:
#   ┌────────────────┬────────────────┐
#   │  ENGINEERING   │   RESEARCH     │
#   ├────────────────┼────────────────┤
#   │  VALIDATION    │   PLANNING     │
#   └────────────────┴────────────────┘
#
# Usage:  pi-fleet            # attach (or create) the "fleet" session
#         pi-fleet kill       # tear it down

set -euo pipefail

SESSION="fleet"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PANE="python3 ${SCRIPT_DIR}/agent_pane.py --persona"

if [[ "${1:-}" == "kill" ]]; then
  tmux kill-session -t "$SESSION" 2>/dev/null || true
  exit 0
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is not installed. Install it (apt install tmux) and re-run." >&2
  exit 1
fi

# Reattach if it already exists.
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach -t "$SESSION"
fi

# Create the session detached, with the engineer pane.
tmux new-session -d -s "$SESSION" -n agents "$PANE engineer"

# Right column (research).
tmux split-window  -h -t "$SESSION:agents" "$PANE research"

# Bottom-left (validation).
tmux split-window  -v -t "$SESSION:agents.0" "$PANE validation"

# Bottom-right (planning) — split the right pane (now pane 2 after the previous split).
tmux split-window  -v -t "$SESSION:agents.2" "$PANE planning"

# Even out the grid.
tmux select-layout -t "$SESSION:agents" tiled

# Styling — keep it scoped to this session so we don't stomp the user's config.
tmux set-option -t "$SESSION" status-position top
tmux set-option -t "$SESSION" status-style       "bg=#11111b,fg=#cdd6f4"
tmux set-option -t "$SESSION" status-left-length 80
tmux set-option -t "$SESSION" status-right-length 80
tmux set-option -t "$SESSION" status-left  " #[fg=#cba6f7,bold]π FLEET #[fg=#585b70]│#[fg=#7f849c] 4 agents #[fg=#585b70]│#[fg=#a6e3a1] running "
tmux set-option -t "$SESSION" status-right "#[fg=#7f849c]ctx #[fg=#cdd6f4]88k #[fg=#585b70]│#[fg=#7f849c] spend #[fg=#cdd6f4]\$7.26 #[fg=#585b70]│#[fg=#7f849c] %H:%M "
tmux set-option -t "$SESSION" window-status-current-format ""
tmux set-option -t "$SESSION" window-status-format         ""
tmux set-option -t "$SESSION" pane-border-style        "fg=#313244"
tmux set-option -t "$SESSION" pane-active-border-style "fg=#89b4fa"
tmux set-option -t "$SESSION" pane-border-status off

exec tmux attach -t "$SESSION"
