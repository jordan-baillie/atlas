{
  "version": "v2.0",
  "project": "Atlas",
  "market": "sp500",
  "description": "SP500 optimized config \u2014 parallel coordinate descent across 284 tickers",
  "universe": {
    "method": "top_liquid",
    "top_n": 200,
    "min_median_daily_value": 5000000,
    "min_price": 5.0,
    "min_market_cap": 2000000000,
    "exclusions": [],
    "benchmark_ticker": "SPY"
  },
  "risk": {
    "starting_equity": 10000,
    "max_risk_per_trade_pct": 0.005,
    "max_open_positions": 10,
    "max_sector_concentration": 2,
    "max_daily_drawdown_pct": 0.02,
    "require_stop_loss": true,
    "require_planned_exit": true,
    "min_confidence": 0.75,
    "trailing_stop": {
      "enabled": false,
      "activation_pct": 0.02,
      "atr_multiplier": 1.5
    }
  },
  "trading": {
    "mode": "paper",
    "broker": "paper",
    "holding_period_min": 2,
    "holding_period_max": 20,
    "data_frequency": "daily",
    "order_type": "market_on_open",
    "approval_required": true,
    "live_safety": {
      "require_double_approval": true,
      "max_order_value": 5000,
      "max_daily_orders": 10,
      "dry_run_first": true
    }
  },
  "fees": {
    "commission_per_trade": 1.1,
    "commission_pct": 0.001,
    "slippage_pct": 0.0005,
    "flat_fee_threshold": 5000.0,
    "min_position_value": 100.0,
    "_broker": "moomoo_us",
    "_fee_notes": "Moomoo US actual fees from order_fee_query (2026-02-26): Platform Fee $0.99 + Settlement Fee ~$0.10 + Trading Activity Fee ~$0.03 = avg $1.09/order. Using $1.10 flat + 0.1% pct (whichever greater above threshold).",
    "_actual_data": "6 US orders over 90 days: avg fee $1.09, avg order value $755. Fee range $0.99-$1.23."
  },
  "strategies": {
    "momentum_breakout": {
      "enabled": false
    },
    "mean_reversion": {
      "enabled": true,
      "rsi_period": 14,
      "rsi_oversold": 35,
      "zscore_lookback": 20,
      "zscore_entry": -2.0,
      "atr_period": 14,
      "atr_stop_mult": 2.5,
      "profit_target_atr_mult": 1.5,
      "max_hold_days": 10,
      "sma200_filter": false,
      "ibs_max": 1.0,
      "volume": {
        "lookback": 20,
        "min_ratio": 0.5,
        "surge_threshold": 1.5,
        "surge_boost": 0.0,
        "dry_penalty": 0.0
      },
      "earnings_blackout": {
        "enabled": true,
        "days_before": 5,
        "days_after": 1
      },
      "breadth": {
        "enabled": true,
        "metric": "pct_above_50ma",
        "low_threshold": 48.0,
        "high_threshold": 58.0,
        "low_boost": 0.015,
        "high_penalty": 0.015
      },
      "relative_strength": {
        "enabled": false
      },
      "cointegration_filter": {
        "enabled": false
      }
    },
    "trend_following": {
      "enabled": true,
      "fast_ma": 15,
      "slow_ma": 20,
      "pullback_pct": 0.04,
      "atr_period": 14,
      "atr_stop_mult": 2.0,
      "trailing_stop_atr_mult": 2.5,
      "max_hold_days": 15,
      "volume": {
        "lookback": 20,
        "min_ratio": 0.5,
        "boost_threshold": 1.5,
        "boost_amount": 0.1,
        "penalty_amount": 0.05
      },
      "breadth": {
        "enabled": true,
        "metric": "pct_above_50ma",
        "low_threshold": 48.0,
        "high_threshold": 58.0,
        "low_boost": 0.03,
        "high_penalty": 0.03
      },
      "relative_strength": {
        "enabled": true,
        "metric": "rs_percentile",
        "low_threshold": 50.0,
        "high_threshold": 60.0,
        "low_penalty": 0.05,
        "high_boost": 0.0
      }
    },
    "opening_gap": {
      "enabled": true,
      "gap_threshold": -0.015,
      "ibs_confirm": 0.5,
      "rsi14_max": 25,
      "vol_surge_threshold": 1.2,
      "atr_period": 14,
      "atr_stop_mult": 1.5,
      "sma_exit_period": 5,
      "ibs_exit_threshold": 0.8,
      "max_hold_days": 7,
      "sma200_filter": false,
      "earnings_blackout": {
        "enabled": false,
        "days_before": 5,
        "days_after": 1
      }
    },
    "sector_rotation": {
      "enabled": false
    },
    "short_term_mr": {
      "enabled": false
    },
    "bb_squeeze": {
      "enabled": false
    },
    "mtf_momentum": {
      "enabled": false
    },
    "dividend_capture": {
      "enabled": false
    }
  },
  "backtest": {
    "train_window_days": 252,
    "test_window_days": 63,
    "step_days": 21,
    "min_history_days": 60
  },
  "data": {
    "source": "yfinance",
    "history_years": 3,
    "cache_dir": "data/cache",
    "raw_dir": "data/raw",
    "processed_dir": "data/processed"
  },
  "annealing": {
    "max_changes_per_cycle": 2,
    "min_oos_sharpe_improvement": 0.05,
    "max_drawdown_increase_pct": 0.01,
    "changelog_file": "journal/changelog.json"
  },
  "dynamic_sizing": {
    "enabled": false
  },
  "fee_aware_filter": {
    "enabled": false
  },
  "regime_filter": {
    "enabled": false
  }
}