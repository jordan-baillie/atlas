    "require_planned_exit": true,
    "min_confidence": 0.65,
    "trailing_stop": {
      "enabled": false,
      "activation_pct": 0.02,
      "atr_multiplier": 2.0
    },
    "max_gross_exposure_pct": 1.75,
    "_max_gross_exposure_note": "2026-04-28 B1: global gross exposure cap (sum(abs MV)/equity). Evaluated at entry time via risk/gross_exposure_guard.py \u2014 rejects new entries if account-wide gross would exceed this value.",
    "last_recalibrated_at": "2026-05-01T08:25:28+00:00"
  },
  "trading": {
    "mode": "passive",
    "broker": "alpaca",
    "live_enabled": false,
    "holding_period_min": 2,
    "holding_period_max": 20,
    "data_frequency": "daily",
    "order_type": "market_on_open",
    "auto_approve": true,
    "live_safety": {
      "require_double_approval": false,
      "max_order_value": 5000,
      "max_daily_orders": 3,
      "dry_run_first": false,
      "max_daily_loss_pct": 0.02
