  "trading": {
    "mode": "paper",
    "holding_period_min": 2,
    "holding_period_max": 20,
    "data_frequency": "daily",
    "order_type": "market_on_open",
    "approval_required": true
  },
  "fees": {
    "commission_per_trade": 5.0,
    "commission_pct": 0.0008,
    "slippage_pct": 0.001,
    "flat_fee_threshold": 2000.0,
    "min_position_value": 500.0
  },
  "strategies": {
    "momentum_breakout": {
      "enabled": false,
      "lookback_days": 20,
      "volume_confirmation_mult": 1.5,
      "atr_period": 14,
      "atr_stop_mult": 3.0,
      "trailing_stop_atr_mult": 3.5,
      "max_hold_days": 15
    },
    "mean_reversion": {
      "enabled": true,
      "rsi_period": 14,
      "rsi_oversold": 35,
      "zscore_lookback": 20,
      "zscore_entry": -2.0,
      "atr_period": 14,
      "atr_stop_mult": 3.0,
      "profit_target_atr_mult": 1.5,
      "max_hold_days": 10,
      "volume": {
        "lookback": 20,
        "min_ratio": 0.5,
        "surge_threshold": 2.0,
        "surge_boost": 0.1,
        "dry_penalty": 0.05
