      "earnings_blackout": {
        "enabled": false,
        "days_before": 5,
        "days_after": 1
      },
      "breadth": {
        "enabled": true,
        "metric": "pct_above_50ma",
        "low_threshold": 48.0,
        "high_threshold": 58.0,
        "low_boost": 0.015,
        "high_penalty": 0.015
      }
    },
    "trend_following": {
      "enabled": true,
      "fast_ma": 10,
      "slow_ma": 30,
      "pullback_pct": 0.02,
      "atr_period": 14,
      "atr_stop_mult": 3.5,
      "trailing_stop_atr_mult": 4.0,
      "max_hold_days": 20,
      "volume": {
        "lookback": 20,
        "min_ratio": 0.5,
        "boost_threshold": 1.5,
        "boost_amount": 0.1,
        "penalty_amount": 0.05
      },
      "breadth": {
        "enabled": true,
        "metric": "pct_above_50ma",
        "low_threshold": 48.0,
        "high_threshold": 58.0,
        "low_boost": 0.03,
        "high_penalty": 0.03
      }
    }
  },
  "backtest": {
    "train_window_days": 252,
    "test_window_days": 63,
    "step_days": 21,
    "min_history_days": 60
  },
  "data": {
    "source": "yfinance",
    "history_years": 3,
    "cache_dir": "data/cache",
    "raw_dir": "data/raw",
    "processed_dir": "data/processed"
  },
  "annealing": {
    "max_changes_per_cycle": 2,
    "min_oos_sharpe_improvement": 0.05,
