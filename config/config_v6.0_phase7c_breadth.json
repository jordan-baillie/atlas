{
  "version": "v6.0_phase7c_breadth",
  "project": "Atlas-ASX",
  "description": "Phase 7C: Market breadth confidence modifiers (pct_above_50ma thresholds 48/58%)",
  "universe": {
    "method": "top_liquid",
    "top_n": 100,
    "min_median_daily_value": 1000000,
    "min_price": 1.0,
    "min_market_cap": 500000000,
    "exclusions": [],
    "benchmark_ticker": "IOZ.AX"
  },
  "risk": {
    "starting_equity": 5000,
    "max_risk_per_trade_pct": 0.005,
    "max_open_positions": 5,
