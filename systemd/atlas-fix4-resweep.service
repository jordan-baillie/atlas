[Unit]
Description=Atlas Fix 4 — re-sweep 8 contaminated research_best combos
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/atlas
EnvironmentFile=-/etc/atlas/atlas.conf
ExecStart=/bin/bash /root/atlas/scripts/fix4_resweep_contaminated.sh
TimeoutStartSec=21600
StandardOutput=journal
StandardError=journal
KillSignal=SIGTERM
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
