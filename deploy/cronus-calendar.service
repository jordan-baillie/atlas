[Unit]
Description=Cronus Calendar Events Agent — check upcoming macro events and issue alerts
After=network.target
Documentation=https://github.com/cronus-trade/cronus

[Service]
Type=oneshot
WorkingDirectory=/root/cronus
Environment=CRONUS_CONFIG=/root/cronus/config/trading_paper.yaml
Environment=PYTHONPATH=/root/cronus
User=root
ExecStart=/usr/bin/python3 /root/cronus/agents/tier2/calendar_events.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
